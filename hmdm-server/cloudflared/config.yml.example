# Cloudflare Named Tunnel config for Brother Pharmach MDM
# Copy this file to config.yml in the same folder and replace placeholders.

tunnel: YOUR_TUNNEL_UUID
credentials-file: /etc/cloudflared/YOUR_TUNNEL_UUID.json

ingress:
  - hostname: brothers-mdm.com
    service: http://hmdm:8080
  - service: http_status:404
